# Firebase web config — copy this to .env.local and fill in values.
# All NEXT_PUBLIC_* vars are inlined into the static build and visible in the browser
# (this is the standard pattern for Firebase web apps — protect data with Firestore rules).
#
# Setup checklist in the Firebase console:
#   1. Project settings → General → "Your apps": register a web app, copy the config below.
#   2. Build → Authentication → Sign-in method:
#        - Enable "Email/Password"
#        - Enable "Google"
#      Add http://localhost:3000 (and any deployed origins) under Authentication →
#      Settings → Authorized domains.
#   3. Build → Firestore Database → create a database (production mode is fine), then add
#      rules so each user can only read/write their own prompts:
#
#        rules_version = '2';
#        service cloud.firestore {
#          match /databases/{db}/documents {
#            match /users/{uid}/{document=**} {
#              allow read, write: if request.auth != null && request.auth.uid == uid;
#            }
#          }
#        }

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
