# =============================================================================
# QA Hub - .gitignore
# Next.js 14 (static export) · TypeScript · Firebase · Netlify
# =============================================================================

# -----------------------------------------------------------------------------
# Dependencies
# -----------------------------------------------------------------------------
node_modules/
.pnp
.pnp.js
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# -----------------------------------------------------------------------------
# Next.js
# -----------------------------------------------------------------------------
.next/
out/
.swc/

# -----------------------------------------------------------------------------
# TypeScript
# -----------------------------------------------------------------------------
*.tsbuildinfo

# -----------------------------------------------------------------------------
# Environment & secrets (never commit keys or Firebase config)
# -----------------------------------------------------------------------------
.env
.env.*
!.env*.example
!.env.example

# -----------------------------------------------------------------------------
# Firebase (local emulators, debug logs, exports)
# -----------------------------------------------------------------------------
.firebase/
firebase-debug.log
firebase-debug.*.log
firestore-debug.log
ui-debug.log
database-debug.log
pubsub-debug.log
*-debug.log

# -----------------------------------------------------------------------------
# Hosting & deploy
# -----------------------------------------------------------------------------
.netlify/
.vercel/

# -----------------------------------------------------------------------------
# Testing & coverage
# -----------------------------------------------------------------------------
coverage/
.nyc_output/
*.lcov
junit.xml
test-results/
playwright-report/
playwright/.cache/
cypress/videos/
cypress/screenshots/

# -----------------------------------------------------------------------------
# Logs & diagnostics
# -----------------------------------------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# -----------------------------------------------------------------------------
# Lint & format caches
# -----------------------------------------------------------------------------
.eslintcache
.prettiercache
.stylelintcache

# -----------------------------------------------------------------------------
# OS & filesystem
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# -----------------------------------------------------------------------------
# Editors & IDEs (keep shared settings via .vscode/extensions.json if needed)
# -----------------------------------------------------------------------------
.idea/
*.iml
*.ipr
*.iws
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json.example
*.sublime-workspace
*.sublime-project
.project
.classpath
.settings/
*.swp
*.swo
*~

# -----------------------------------------------------------------------------
# Misc build & temp
# -----------------------------------------------------------------------------
dist/
build/
.cache/
.parcel-cache/
.turbo/
tmp/
temp/
*.tmp
*.temp
*.pid
*.seed
*.pid.lock

# -----------------------------------------------------------------------------
# Optional local tooling
# -----------------------------------------------------------------------------
.envrc
.direnv/
