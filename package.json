{
  "name": "qa-hub",
  "version": "0.1.0",
  "private": true,
  "description": "A unified web app of everyday tools for QA engineers.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,md}\"",
    "typecheck": "tsc --noEmit",
    "prepare": "husky"
  },
  "dependencies": {
    "@faker-js/faker": "^9.0.3",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "diff": "^7.0.0",
    "firebase": "^10.14.1",
    "js-yaml": "^4.1.0",
    "jsonpath-plus": "^10.0.7",
    "lucide-react": "^0.460.0",
    "next": "14.2.35",
    "prismjs": "^1.29.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-simple-code-editor": "^0.14.1",
    "tailwind-merge": "^2.5.4"
  },
  "devDependencies": {
    "@types/diff": "^5.2.3",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.7.5",
    "@types/prismjs": "^1.26.5",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "14.2.35",
    "eslint-config-prettier": "^9.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.10",
    "postcss": "^8.4.47",
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.6.8",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.6.3"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,md,json,yml,yaml}": [
      "prettier --write"
    ]
  }
}
